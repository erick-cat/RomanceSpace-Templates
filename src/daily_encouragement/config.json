{
  "name": "daily_encouragement",
  "title": "日常鼓励充电站",
  "version": "1.0.0",
  "static": false,
  "description": "每天给自己一点鼓励和正能量",
  "tier": "free",
  "fields": [
    {
      "id": "user_name",
      "label": "用户名称",
      "placeholder": "输入你的名字",
      "default": "朋友",
      "type": "text"
    },
    {
      "id": "daily_quote",
      "label": "今日鼓励语",
      "placeholder": "输入一句鼓励的话",
      "default": "今天的你，已经做得很好了",
      "type": "textarea"
    },
    {
      "id": "mood_score",
      "label": "今日心情指数",
      "placeholder": "0-10分",
      "default": "7",
      "type": "text"
    },
    {
      "id": "streak_days",
      "label": "连续打卡天数",
      "placeholder": "输入数字",
      "default": "1",
      "type": "text"
    }
  ]
}