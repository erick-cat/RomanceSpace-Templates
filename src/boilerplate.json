{
  "name": "boilerplate_v2",
  "version": "1.1.0",
  "static": false,
  "show_viral_footer": true,
  "meta": {
    "theme_color": "#ff4d6d",
    "mobile_first": true
  },
  "css_standards": [
    "box-sizing: border-box",
    "img { max-width: 100% }"
  ],
  "fields": [
    {
      "id": "title",
      "label": "网页标题",
      "placeholder": "输入浪漫的标题",
      "default": "致最亲爱的你",
      "type": "text"
    },
    {
      "id": "message",
      "label": "浪漫留言",
      "placeholder": "想对 TA 说的话...",
      "default": "愿年年岁岁，常伴左右。",
      "type": "textarea"
    }
  ]
}
